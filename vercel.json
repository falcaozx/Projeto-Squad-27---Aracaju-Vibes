{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": null,
  "buildCommand": "npm run build && node scripts/vercel-prepare.mjs",
  "outputDirectory": null,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/api"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}
